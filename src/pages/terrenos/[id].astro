---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const terrenos = await getCollection('terrenos');
  return terrenos.map(terreno => ({
    params: { id: terreno.id },
    props: { terreno },
  }));
}

const { terreno } = Astro.props;
const { title, precio, area, ubicacion, status, image } = terreno.data;
const { Content } = await render(terreno);

const baseUrl = import.meta.env.BASE_URL;

const statusColors = {
  disponible: "bg-green-100 text-green-700 border-green-200",
  vendido: "bg-red-100 text-red-700 border-red-200",
  reservado: "bg-orange-100 text-orange-700 border-orange-200"
};
---

<BaseLayout title={title}>
  <article class="max-w-6xl mx-auto py-12 px-6">
    <nav class="flex justify-between items-center mb-12">
      <a href={baseUrl} class="group text-slate-500 font-medium inline-flex items-center gap-2 hover:text-blue-600 transition-colors">
        <div class="p-2 bg-white rounded-lg shadow-sm group-hover:shadow-md transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </div>
        Volver al catálogo
      </a>
      <div class="hidden md:block text-sm text-slate-400 font-medium">
        Terrenos en Tacna / <span class="text-slate-900">{title}</span>
      </div>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      
      <div class="lg:col-span-2 space-y-12">
        
        <div class="relative rounded-[2rem] overflow-hidden shadow-2xl animate-fade-in group">
          <img src={image} alt={title} class="w-full aspect-[16/10] object-cover" />
          <div class="absolute top-6 left-6">
            <span class={`px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest border shadow-sm ${statusColors[status]}`}>
              {status}
            </span>
          </div>
        </div>

        <div class="bg-white p-8 md:p-12 rounded-[2rem] shadow-sm border border-slate-100 relative">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 pb-10 border-b border-slate-50">
            <div>
              <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight mb-2">{title}</h1>
              <p class="text-lg text-slate-500 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor font-bold">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                {ubicacion}, Tacna
              </p>
            </div>
            <div class="text-left md:text-right">
              <p class="text-3xl font-black text-blue-600">${precio.toLocaleString()}</p>
              <p class="text-sm font-bold text-slate-400 uppercase tracking-widest">{area} m² Totales</p>
            </div>
          </div>

          <h2 class="text-2xl font-black text-slate-900 mb-6 flex items-center gap-3">
            <span class="w-1.5 h-8 bg-blue-600 rounded-full"></span>
            Descripción de la propiedad
          </h2>
          
          <div class="prose prose-slate prose-lg max-w-none 
            prose-headings:font-black prose-headings:text-slate-900
            prose-p:text-slate-600 prose-p:leading-relaxed
            prose-strong:text-blue-700 prose-strong:font-bold">
            <Content />
          </div>
        </div>
      </div>

      <aside class="lg:col-span-1">
        <div class="sticky top-8 space-y-6 animate-fade-in" style="animation-delay: 0.2s;">
          
          <div class="bg-slate-900 rounded-[2rem] p-8 text-white shadow-2xl shadow-blue-900/20">
            <h3 class="text-2xl font-bold mb-4 italic">¿Te interesa este lote?</h3>
            <p class="text-slate-400 mb-8 leading-relaxed">
              Solicita información detallada, planos legales o agenda una visita guiada al terreno hoy mismo.
            </p>
            
            <div class="space-y-4">
              <a 
                href={`https://wa.me/51975056821?text=Hola, estoy interesado en el terreno: ${title}`}
                target="_blank"
                class="flex items-center justify-center gap-3 w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 rounded-2xl transition-all hover:scale-[1.02] active:scale-95 shadow-lg shadow-green-900/30"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.631 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp Directo
              </a>
              <button class="w-full bg-white/10 hover:bg-white/20 text-white font-bold py-4 rounded-2xl transition-all border border-white/5">
                Descargar ficha técnica
              </button>
            </div>

            <div class="mt-8 pt-8 border-t border-white/10">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center font-black text-xl">
                  FP
                </div>
                <div>
                  <p class="text-xs text-slate-500 uppercase font-bold tracking-widest">Asesor Experto</p>
                  <p class="font-bold text-white">Florent Planells</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-blue-50 border border-blue-100 rounded-[2rem] p-6 flex items-center gap-4">
            <div class="text-2xl text-blue-600">⚖️</div>
            <p class="text-sm text-blue-800 font-medium">Propiedad verificada legalmente con Título en RRPP.</p>
          </div>

        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .animate-fade-in {
    opacity: 0;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Rendre le contenu Markdown encore plus élégant */
  .prose :global(p) {
    margin-bottom: 1.5em;
  }
  .prose :global(ul) {
    list-style-type: none;
    padding-left: 0;
  }
  .prose :global(li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(li::before) {
    content: "→";
    position: absolute;
    left: 0;
    color: #2563eb;
    font-weight: bold;
  }
</style>