---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CardTerreno from '../components/CardTerreno.astro';
import WhatsAppFab from '../components/ui/WhatsAppFab.astro';

const allTerrenos = await getCollection('terrenos') || [];
---

<BaseLayout title="Inicio | Venta de Lotes">
  <header class="bg-slate-900 text-white pt-20 pb-32 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <span class="inline-block bg-blue-600 text-[10px] font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-widest animate-fade-in">Tacna - Perú</span>
      <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tight animate-fade-in">
        Tu futuro hogar comienza en un <span class="text-blue-400 font-extrabold italic">buen lote.</span>
      </h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto font-light animate-fade-in" style="animation-delay: 0.1s">
        Especialistas en terrenos residenciales y agrícolas en Pocollay, La Yarada y Tacna Centro.
      </p>
    </div>
  </header>

  <section class="max-w-4xl mx-auto -mt-16 px-6 relative z-10">
    <div class="bg-white p-4 rounded-2xl shadow-2xl border border-slate-100 flex flex-wrap md:flex-nowrap gap-4 items-center">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-[10px] uppercase font-bold text-slate-400 ml-2">Ubicación</label>
        <select id="filter-location" class="w-full bg-transparent font-medium text-slate-900 focus:outline-none cursor-pointer">
          <option value="all">Todos los distritos</option>
          <option value="Pocollay">Pocollay</option>
          <option value="La Yarada">La Yarada</option>
          <option value="Tacna Centro">Tacna Centro</option>
        </select>
      </div>
      <div class="h-10 w-[1px] bg-slate-100 hidden md:block"></div>
      <div class="flex-1 min-w-[200px]">
        <label class="block text-[10px] uppercase font-bold text-slate-400 ml-2">Presupuesto Máximo</label>
        <select id="filter-price" class="w-full bg-transparent font-medium text-slate-900 focus:outline-none cursor-pointer">
          <option value="all">Cualquier precio</option>
          <option value="50000">Hasta $50,000</option>
          <option value="100000">Hasta $100,000</option>
          <option value="200000">Hasta $200,000</option>
        </select>
      </div>
      <button id="search-btn" class="w-full md:w-auto bg-blue-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-700 transition-all shadow-lg shadow-blue-200 active:scale-95">
        Buscar
      </button>
    </div>
  </section>

  <main class="max-w-6xl mx-auto py-20 px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4">
      <div>
        <h2 class="text-3xl font-black text-slate-900">Propiedades Destacadas</h2>
        <p class="text-slate-500">Los mejores lotes disponibles hoy en Tacna</p>
      </div>
      <div class="text-sm font-bold text-slate-400 uppercase tracking-widest bg-slate-50 px-4 py-2 rounded-lg border border-slate-100">
        <span id="result-count" class="text-blue-600">{allTerrenos.length}</span> Terrenos encontrados
      </div>
    </div>

    {allTerrenos.length === 0 && (
      <div class="bg-red-50 border-2 border-dashed border-red-200 p-8 rounded-2xl text-center">
        <p class="text-red-600 font-bold text-lg">⚠️ No se encontraron archivos en src/content/terrenos/</p>
      </div>
    )}

    <div id="terrenos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 animate-fade-in opacity-0 [animation-fill-mode:forwards]">
      {allTerrenos.map((terreno) => (
        <div class="terreno-item transition-all duration-500" 
             data-location={terreno.data.ubicacion} 
             data-price={terreno.data.precio}>
          <CardTerreno 
            id={terreno.id} 
            title={terreno.data.title}
            price={terreno.data.precio}
            area={terreno.data.area}
            location={terreno.data.ubicacion}
            status={terreno.data.status}
            image={terreno.data.image}
          />
        </div>
      ))}
    </div>

    <div id="no-results" class="hidden py-20 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-slate-100 rounded-full mb-6">
        <span class="text-4xl">🔎</span>
      </div>
      <h3 class="text-xl font-bold text-slate-900 mb-2">No hay coincidencias</h3>
      <p class="text-slate-500">Intenta ajustar los filtros de búsqueda o el presupuesto.</p>
    </div>
  </main>

  <WhatsAppFab phone="51975056821" message="Hola! Me interesa información sobre los terrenos en Tacna." />
</BaseLayout>

<script>
  function applyFilters() {
    const filterLocation = document.getElementById('filter-location') as HTMLSelectElement;
    const filterPrice = document.getElementById('filter-price') as HTMLSelectElement;
    const items = document.querySelectorAll('.terreno-item') as NodeListOf<HTMLElement>;
    const resultCount = document.getElementById('result-count');
    const noResults = document.getElementById('no-results');

    const locValue = filterLocation.value.trim().toLowerCase();
    const priceLimit = filterPrice.value === 'all' ? Infinity : parseFloat(filterPrice.value);
    
    let visibleCount = 0;

    items.forEach(item => {
      const itemLoc = item.getAttribute('data-location')?.trim().toLowerCase() || '';
      const itemPrice = parseFloat(item.getAttribute('data-price') || '0');

      const matchesLoc = locValue === 'all' || itemLoc === locValue;
      const matchesPrice = itemPrice <= priceLimit;

      // DEBUG: Décommente la ligne suivante pour voir ce qui bloque dans la console F12
      // console.log(`Terrain: ${itemLoc}, Prix: ${itemPrice} | Filtre: ${locValue}, Max: ${priceLimit} | Match: ${matchesLoc && matchesPrice}`);

      if (matchesLoc && matchesPrice) {
        item.style.display = 'block';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });

    if (resultCount) resultCount.textContent = visibleCount.toString();
    if (noResults) {
      visibleCount === 0 ? noResults.classList.remove('hidden') : noResults.classList.add('hidden');
    }
  }

  document.getElementById('search-btn')?.addEventListener('click', applyFilters);
  document.getElementById('filter-location')?.addEventListener('change', applyFilters);
  document.getElementById('filter-price')?.addEventListener('change', applyFilters);

  // Initialisation au chargement
  window.addEventListener('DOMContentLoaded', applyFilters);
</script>