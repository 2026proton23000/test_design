---
import '../styles/global.css';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Venta de terrenos exclusivos en Tacna" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
// Normalisation : on enlève le slash final s'il existe
const cleanBase = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${cleanBase}/favicon.svg`} />
    <link rel="alternate icon" href={`${cleanBase}/favicon.ico`} />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Inmobiliaria Tacna</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-50 min-h-screen flex flex-col">
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>