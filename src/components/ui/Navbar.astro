---
const baseUrl = import.meta.env.BASE_URL;
const { pathname } = Astro.url;

const activePath = pathname.replace(/\/$/, "");
const cleanBaseUrl = baseUrl.replace(/\/$/, "");

const navLinks = [
  { name: 'Inicio', href: baseUrl },
  { name: 'Proyectos', href: `${cleanBaseUrl}/proyectos/` },
  { name: 'Nosotros', href: `${cleanBaseUrl}/nosotros/` },
];
---

<nav class="sticky top-0 z-40 w-full border-b border-slate-100 bg-white/80 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <!-- Logo -->
    <a href={baseUrl} class="flex items-center gap-2 group">
      <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center text-white font-black text-xl shadow-lg shadow-blue-200 group-hover:scale-110 transition-transform">
        T
      </div>
      <span class="text-xl font-black tracking-tighter text-slate-900 uppercase">
        Tacna<span class="text-blue-600">Lotes</span>
      </span>
    </a>
    
    <!-- Menu desktop (visible à partir de md) -->
    <div class="hidden md:flex items-center gap-8 font-bold text-sm uppercase tracking-widest text-slate-500">
      {navLinks.map(link => {
        const isActive = activePath === link.href || (link.name === 'Inicio' && activePath === cleanBaseUrl);
        return (
          <a 
            href={link.href} 
            class={`transition-colors hover:text-blue-600 ${isActive ? 'text-blue-600' : ''}`}
          >
            {link.name}
          </a>
        );
      })}
      
      <a href="tel:+51975056821" class="bg-slate-900 text-white px-6 py-3 rounded-full text-xs hover:bg-blue-600 transition-all shadow-xl shadow-slate-200 active:scale-95">
        Llamar ahora
      </a>
    </div>

    <!-- Bouton burger (visible seulement en mobile) -->
    <button 
      class="md:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors"
      id="menu-toggle"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Menu mobile (caché par défaut, apparaît quand #menu-mobile n'a pas la classe 'hidden') -->
  <div id="menu-mobile" class="md:hidden hidden absolute left-0 right-0 top-20 bg-white border-b border-slate-100 shadow-lg p-4 flex-col gap-4 font-bold text-sm uppercase tracking-widest text-slate-500">
    {navLinks.map(link => {
      const isActive = activePath === link.href || (link.name === 'Inicio' && activePath === cleanBaseUrl);
      return (
        <a 
          href={link.href} 
          class={`block py-2 px-4 hover:bg-slate-50 rounded-lg transition-colors hover:text-blue-600 ${isActive ? 'text-blue-600' : ''}`}
        >
          {link.name}
        </a>
      );
    })}
    <a href="tel:+51975056821" class="bg-slate-900 text-white text-center px-6 py-3 rounded-full text-xs hover:bg-blue-600 transition-all shadow-xl shadow-slate-200 active:scale-95">
      Llamar ahora
    </a>
  </div>
</nav>

<!-- Script pour gérer l'ouverture/fermeture du menu mobile -->
<script>
  const toggleButton = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('menu-mobile');

  if (toggleButton && mobileMenu) {
    toggleButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Optionnel : fermer le menu si on clique sur un lien
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });

    // Optionnel : fermer le menu si on redimensionne au-dessus de md
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) { // 768px est le breakpoint md par défaut de Tailwind
        mobileMenu.classList.add('hidden');
      }
    });
  }
</script>