---
// src/components/CardTerreno.astro
const { id, title, price, area, location, status, image } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// Normalisation : on enlève le slash final s'il existe
const cleanBase = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
// Construction du lien avec un seul slash et le slash final obligatoire
const link = `${cleanBase}/terrenos/${id}/`;

const statusColors = {
  disponible: "bg-green-100 text-green-700",
  vendido: "bg-red-100 text-red-700",
  reservado: "bg-orange-100 text-orange-700"
};
---

<a href={link} class="group block">
  <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-slate-100">
    <div class="relative h-56 overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
      <div class="absolute top-4 right-4">
        <span class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${statusColors[status]}`}>
          {status}
        </span>
      </div>
    </div>
    
    <div class="p-6">
      <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">{title}</h3>
      <div class="flex items-center gap-2 text-slate-500 text-sm mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        </svg>
        {location}
      </div>
      
      <div class="flex justify-between items-center pt-4 border-t border-slate-50">
        <div>
          <p class="text-xs text-slate-400 uppercase font-bold">Precio</p>
          <p class="text-2xl font-black text-blue-600">${price.toLocaleString()}</p>
        </div>
        <div class="text-right">
          <p class="text-xs text-slate-400 uppercase font-bold">Área</p>
          <p class="font-bold text-slate-700">{area} m²</p>
        </div>
      </div>
    </div>
  </div>
</a>